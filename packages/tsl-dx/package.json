{
  "name": "tsl-dx",
  "version": "0.13.2",
  "description": "A tsl plugin for better JavaScript/TypeScript DX.",
  "keywords": [
    "tsl",
    "tsl-dx"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Rel1cx/dx"
  },
  "license": "MIT",
  "author": "Rel1cx<let@ik.me>",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown --dts-resolve",
    "build:docs": "typedoc",
    "lint:publish": "publint",
    "lint:ts": "tsl",
    "publish": "node --run build && node --run lint:publish",
    "test": "vitest"
  },
  "dependencies": {
    "ts-pattern": "^5.9.0"
  },
  "devDependencies": {
    "@liautaud/typezod": "^2.0.0",
    "@local/configs": "workspace:*",
    "@local/eff": "workspace:*",
    "dedent": "^1.7.2",
    "tsdown": "^0.22.4",
    "tsl": "^1.0.30",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "tsl": "^1.0.30",
    "typescript": "*"
  },
  "publishConfig": {
    "access": "public"
  }
}
