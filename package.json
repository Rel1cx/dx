{
  "name": "dx",
  "version": "0.13.2",
  "private": true,
  "description": "Monorepo for JavaScript and TypeScript dx libraries.",
  "homepage": "https://github.com/Rel1cx/dx",
  "bugs": {
    "url": "https://github.com/Rel1cx/dx/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Rel1cx/dx"
  },
  "license": "MIT",
  "author": "Rel1cx<let@ik.me>",
  "type": "module",
  "scripts": {
    "build": "node --run build:pkgs && node --run build:packages",
    "build:docs": "pnpm -r --stream --filter \"./packages/**\" run build:docs",
    "build:packages": "pnpm -r --stream --filter \"./packages/**\" run build",
    "build:pkgs": "pnpm -r --stream --filter \"./.pkgs/*\" run build",
    "format:check": "dprint check",
    "format:write": "dprint fmt",
    "lint": "node --run lint:publish && node --run lint:ts && node --run lint:text",
    "lint:arch": "sentrux gate",
    "lint:publish": "pnpm m run lint:publish",
    "lint:text": "textlint '**/*.md' '**/*.mdx'",
    "lint:ts": "pnpm m run lint:ts",
    "prepare": "node --run build",
    "test": "pnpm m run test",
    "update:version": "tsx ./scripts/update-version.ts"
  },
  "devDependencies": {
    "@effect/platform-node": "^4.0.0-beta.90",
    "@local/configs": "workspace:*",
    "@local/eff": "workspace:*",
    "@textlint-rule/textlint-rule-pattern": "^2.0.2",
    "@textlint/textlint-plugin-markdown": "^15.7.1",
    "@tsconfig/node24": "^24.0.4",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^26.0.1",
    "ansis": "^4.3.1",
    "dprint": "^0.54.0",
    "effect": "^4.0.0-beta.90",
    "publint": "^0.3.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sort-package-json": "^4.0.0",
    "textlint": "^15.7.1",
    "tinyglobby": "^0.2.17",
    "ts-pattern": "^5.9.0",
    "tsdown": "^0.22.3",
    "tsl": "^1.0.30",
    "tsl-dx": "workspace:*",
    "tsx": "latest",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typedoc-plugin-mdn-links": "^5.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24.0.0"
  }
}
